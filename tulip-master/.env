##############################
# Tulip config
##############################

# Timescale connection
TIMESCALE="postgres://tulip@timescale:5432/tulip"

# The location of your pcaps as seen by the host
TRAFFIC_DIR_HOST="./services/pcaps/tcpdump/3000" #esecuzione di pluto

# The location of your pcaps (and eve.json), as seen by the container
TRAFFIC_DIR_DOCKER="/traffic"


##############################
# Game config
##############################

TICK_START="2026-06-19T08:00:00Z"

TICK_LENGTH=120000

FLAG_REGEX="[A-Z0-9]{31}="

#Da cambiare ogni vollta!
VM_IP="10.60.5.1"
TEAM_ID="5"

##############################
# PCAP_OVER_IP CONFIGS
##############################

PCAP_OVER_IP=

##############################
# DUMP_PCAPS CONFIGS
##############################

DUMP_PCAPS=

DUMP_PCAPS_INTERVAL="1m"
DUMP_PCAPS_FILENAME="2006-01-02_15-04-05.pcap"

##############################
# FLAGID CONFIGS
##############################

FLAGID_SCRAPE=

FLAGID_SCAN=

FLAG_LIFETIME=

#endpoint di gara, controllare se è giusto, se no cambiarlo con quello corretto
FLAGID_ENDPOINT="http://10.10.0.1:8081/flagIds"

##############################
# FLAG_VALIDATOR CONFIGS
##############################


FLAG_VALIDATOR_TYPE=

#cambia ogni volta, deve essere uguale a quello di TEAM_ID
FLAG_VALIDATOR_TEAM=5

